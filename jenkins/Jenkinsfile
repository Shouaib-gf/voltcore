pipeline {
  agent any

  parameters {
    string(name: 'VM_NAME',           defaultValue: '')
    string(name: 'VM_ID',             defaultValue: '')
    string(name: 'CLIENT_ID',         defaultValue: '')
    string(name: 'CLIENT_EMAIL',      defaultValue: '')
    string(name: 'CLIENT_SSH_PUBKEY', defaultValue: '')
    string(name: 'PLAN',              defaultValue: 'basic')
    string(name: 'OS',                defaultValue: 'ubuntu-22.04')
    string(name: 'CPU_CORES',         defaultValue: '2')
    string(name: 'RAM_MB',            defaultValue: '2048')
    string(name: 'DISK_GB',           defaultValue: '40')
    string(name: 'ACTION',            defaultValue: 'apply')
  }

  stages {

    stage('Validate') {
      steps {
        script {
          if (!params.VM_NAME || !params.VM_ID || !params.CLIENT_ID) {
            error("Missing required parameters: VM_NAME, VM_ID, CLIENT_ID")
          }
          echo "VM: ${params.VM_NAME} | Action: ${params.ACTION}"
        }
      }
    }

    stage('TF Init') {
      steps {
        withCredentials([
          string(credentialsId: 'minio-access-key', variable: 'AWS_ACCESS_KEY_ID'),
          string(credentialsId: 'minio-secret-key', variable: 'AWS_SECRET_ACCESS_KEY')
        ]) {
          sh '''
            cd /opt/voltcore/terraform

            terraform init -reconfigure \
              -backend-config="access_key=$AWS_ACCESS_KEY_ID" \
              -backend-config="secret_key=$AWS_SECRET_ACCESS_KEY"
          '''
        }
      }
    }

    stage('TF Plan') {
      steps {
        withCredentials([
          string(credentialsId: 'proxmox-api-token', variable: 'TF_VAR_proxmox_api_token'),
          string(credentialsId: 'minio-access-key',  variable: 'AWS_ACCESS_KEY_ID'),
          string(credentialsId: 'minio-secret-key',  variable: 'AWS_SECRET_ACCESS_KEY')
        ]) {
          sh '''
            cd /opt/voltcore/terraform

            export AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID
            export AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY

            terraform plan -out=tfplan \
              -var "proxmox_api_url=https://192.168.0.143:8006/api2/json" \
              -var "vm_name=$VM_NAME" \
              -var "vm_id=$VM_ID" \
              -var "client_id=$CLIENT_ID" \
              -var "client_email=$CLIENT_EMAIL" \
              -var "client_ssh_pubkey=$CLIENT_SSH_PUBKEY" \
              -var "plan=$PLAN" \
              -var "os=$OS" \
              -var "cpu_cores=$CPU_CORES" \
              -var "ram_mb=$RAM_MB" \
              -var "disk_gb=$DISK_GB"
          '''
        }
      }
    }

    stage('TF Apply') {
      steps {
        withCredentials([
          string(credentialsId: 'proxmox-api-token', variable: 'TF_VAR_proxmox_api_token'),
          string(credentialsId: 'minio-access-key',  variable: 'AWS_ACCESS_KEY_ID'),
          string(credentialsId: 'minio-secret-key',  variable: 'AWS_SECRET_ACCESS_KEY')
        ]) {
          sh '''
            cd /opt/voltcore/terraform

            export AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID
            export AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY

            terraform apply -auto-approve tfplan
          '''
        }
      }
    }

    stage('Output') {
      when { expression { params.ACTION == 'apply' } }
      steps {
        script {

          // Install jq if not present
          sh 'apt-get update && apt-get install -y jq || apk add --no-cache jq'

          def ip = sh(
            script: '''
              cd /opt/voltcore/terraform
              terraform output -json vm_ipv4 | jq -r '.[1][0]' 2>/dev/null || echo pending
            ''',
            returnStdout: true
          ).trim()

          echo "VM ${params.VM_NAME} IP: ${ip}"
        }
      }
    }

  }

  post {
    success { echo "SUCCESS: ${params.VM_NAME}" }
    failure { echo "FAILED: ${params.VM_NAME}" }
  }
}
